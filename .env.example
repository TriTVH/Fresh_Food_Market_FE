# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# API Configuration
VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_TIMEOUT=10000

# Cloudinary Configuration (image upload)
# Only CLOUD_NAME and unsigned UPLOAD_PRESET are used on frontend.
# DO NOT put API_SECRET in frontend env (bảo mật).
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset_here

# Firebase Configuration (if using Firebase)
# VITE_FIREBASE_API_KEY=your_api_key_here
# VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
# VITE_FIREBASE_PROJECT_ID=your_project_id_here

# Payment Gateway (if needed)
# VITE_PAYMENT_PUBLIC_KEY=your_payment_key_here

# Google Analytics (optional)
# VITE_GA_TRACKING_ID=your_ga_id_here
